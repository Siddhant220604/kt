# Copy this file to .env and set values before running docker-compose

MONGO_URL=mongodb://mongo:27017
DB_NAME=kiran_traders
FRONTEND_URL=http://localhost:3000

# Comma-separated list of origins allowed to call the API (no spaces), e.g.
# https://kirantraders.com,https://www.kirantraders.com
# Defaults to '*' (all origins) if unset - fine for local dev, but should always be set
# explicitly to your real frontend domain(s) in any publicly reachable deployment.
CORS_ORIGINS=http://localhost:3000

# Long random secret used to sign admin/customer auth tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Anyone who has (or guesses) this value can forge admin tokens - never reuse a sample value.
JWT_SECRET=change_me_to_a_long_random_value

# Seeds one admin account on first startup if no admin user exists yet in the database.
# Only used once (at creation) - safe to leave set permanently, doesn't get re-applied to an
# already-seeded account except to keep the "protected root account" flag current.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# Comma-separated IPs/CIDRs of your reverse proxy (e.g. Nginx Proxy Manager). Rate limiting and
# audit logs key off the caller's IP, taken from the X-Forwarded-For header - but that header is
# only trusted when it comes via one of these addresses, so a client that reaches the app
# directly can't spoof it. Defaults to loopback only (127.0.0.1,::1), which is correct if the
# proxy runs on the same host and connects over localhost. If your proxy is a separate container
# reaching the app over a Docker network, set this to that network's subnet instead (e.g.
# 172.18.0.0/16 - check with `docker network inspect`), and firewall the app's port so it's
# reachable ONLY from the proxy, never directly from the public internet.
TRUSTED_PROXY_IPS=127.0.0.1,::1

# Razorpay credentials
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# WhatsApp / Meta configuration
WHATSAPP_DEFAULT_COUNTRY_CODE=+91
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token
WHATSAPP_API_VERSION=v23.0
# App secret from Meta App Dashboard > Settings > Basic - used to verify incoming webhook
# POSTs are genuinely from Meta. Optional (webhook still works without it) but recommended.
WHATSAPP_APP_SECRET=your_whatsapp_app_secret

# Optional links and delays
GOOGLE_REVIEW_LINK=https://g.page/your-business
REVIEW_REQUEST_DELAY_SECONDS=86400

# Frontend build-time API URL
REACT_APP_BACKEND_URL=http://localhost:8000
